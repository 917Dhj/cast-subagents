{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/hooks/session_start.py\"",
            "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\hooks\\session_start.py\"",
            "timeout": 5,
            "statusMessage": "Loading Diverter Advisory Gate..."
          }
        ]
      }
    ]
  }
}
